{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx block-no-verify@1.1.2"
          }
        ],
        "description": "Block git hook-bypass flags (--no-verify)",
        "id": "pre:bash:block-no-verify"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/config-protection.js"
          }
        ],
        "description": "Block modifications to linter/formatter config files",
        "id": "pre:write:config-protection"
      }
    ]
  }
}
